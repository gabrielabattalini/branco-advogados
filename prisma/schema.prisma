// Banco do Sistema Jurídico — Branco Advogados
// Postgres (Neon) — mesma base em dev e produção (Vercel).
// Usa a conexão DIRETA (DATABASE_URL_UNPOOLED) por ser a mais estável com o Prisma.
// Enums são representados como String (portável).

generator client {
  provider      = "prisma-client-js"
  // "native" = local (Windows); "rhel-openssl-3.0.x" = runtime serverless da Vercel.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_UNPOOLED")
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  iniciais  String   @unique
  email     String   @unique
  senhaHash String? // hash scrypt "salt:hash"; nulo até definir senha
  area      String   @default("civel") // civel | trabalhista
  papel     String // coordenador | advogado
  ativo     Boolean  @default(true)
  // Anti-bruteforce: tentativas de senha erradas + bloqueio temporário.
  tentativasLogin Int       @default(0)
  bloqueadoAte    DateTime?
  // Notificações no Telegram: chatId vinculado + token temporário de vínculo.
  // (sem @unique de propósito: o token é aleatório e efêmero, e o @unique faria
  // o `prisma db push` do deploy exigir --accept-data-loss.)
  telegramChatId  String?
  telegramToken   String?
  criadoEm        DateTime  @default(now())
}

// Código de verificação enviado por e-mail no login de um aparelho novo (2FA).
model CodigoLogin {
  id         String   @id @default(cuid())
  usuarioId  String
  codigoHash String // hash do código de 6 dígitos
  expiraEm   DateTime
  tentativas Int      @default(0)
  criadoEm   DateTime @default(now())

  @@index([usuarioId])
}

// Log de acessos (auditoria/LGPD): quem tentou entrar, quando, de onde.
model LoginLog {
  id        String   @id @default(cuid())
  usuarioId String? // nulo se o e-mail não existe
  email     String
  evento    String // sucesso | senha_errada | bloqueado | codigo_enviado | codigo_errado | novo_aparelho
  ip        String   @default("")
  navegador String   @default("") // user-agent resumido
  criadoEm  DateTime @default(now())

  @@index([criadoEm])
  @@index([usuarioId])
}

// Conta de acesso ao PORTAL DO CLIENTE (área externa, só leitura). Cada conta
// representa uma empresa/cliente e vê apenas os processos cujo campo `cliente`
// casa com `nomeCliente`. Totalmente separada dos usuários da equipe.
model ClienteAcesso {
  id           String    @id @default(cuid())
  nomeCliente  String // deve casar com Processo.cliente
  login        String    @unique // identificador que o cliente digita
  senhaHash    String? // nulo até o escritório definir a senha inicial
  ativo        Boolean   @default(true)
  ultimoAcesso DateTime?
  acessos      Int       @default(0)
  tentativas   Int       @default(0)
  bloqueadoAte DateTime?
  criadoEm     DateTime  @default(now())
}

// Configuração de envio do relatório mensal por cliente (importada da planilha).
model ClienteRelatorio {
  id          String   @id @default(cuid())
  nome        String // casa com Processo.cliente
  emails      String   @default("") // destinatários, separados por ; ou ,
  corpoEmail  String   @default("") // texto do e-mail; {MES_ANO_REFERENCIA_TITULO} = mês/ano
  nomeArquivo String   @default("") // base do nome do PDF anexado
  tipo        String   @default("") // PF | PJ
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())

  @@index([nome])
}

model Contato {
  id            String   @id @default(cuid())
  tipo          String // pf | pj
  nome          String
  documento     String
  tipoContato   String // cliente | parte_contraria | advogado_contrario | parte_processo | fornecedor | interno | perito | correspondente | diverso
  profissao     String   @default("") // Profissão / Nome fantasia
  telefone      String   @default("")
  email         String   @default("")
  ativo         Boolean  @default(true)
  classificacao String   @default("") // rótulo bruto do Legal One (Classificações)
  grupos        String   @default("") // rótulo bruto do Legal One (Grupos)
  iniciais      String
  processosCount Int     @default(0)
  criadoEm      DateTime @default(now())

  @@index([tipoContato])
  @@index([nome])
}

model Processo {
  id                  String       @id @default(cuid())
  numero              String       @unique
  area                String // trabalhista | civel
  tribunal            String
  status              String       @default("Em andamento")
  cliente             String
  parteContraria      String
  responsavel         String // nome
  responsavelIniciais String
  valorCausa          String
  distribuido         String
  fase                String
  // Campos fixos do relatório do cliente (pré-cadastrados; só o status muda).
  parteContrariaTipo  String       @default("") // autora | ré | executada | exequente | embargante...
  juizo               String       @default("") // vara/comarca (JUÍZO)
  sinteseDoPedido     String       @default("")
  valorEstimado       String       @default("")
  audienciaRel        String       @default("") // texto da audiência no relatório (vazio = puxa da próxima audiência)
  observacoesRel      String       @default("") // observações do relatório
  // Modalidade do lançamento no relatório do cliente. Separa em seções:
  // judicial | recuperacao_falencia | procon | administrativo | outro
  categoria           String       @default("judicial")
  infoAdicional       String       @default("") // dados extras (ex.: crédito habilitado em RJ/falência)
  arquivoOrigem       String       @default("") // nome do .docx importado — casa com a planilha de envio
  criadoEm            DateTime     @default(now())
  tarefas             Tarefa[]
  documentos          Documento[]
  publicacoes         Publicacao[]
  audiencias          Audiencia[]
  andamentos          ProcessoAndamento[]
}

// Histórico da "situação atual" do processo. Cada vez que uma tarefa do
// processo é concluída, pedimos um breve resumo — que vira o andamento mais
// recente. O relatório mensal do cliente puxa o último de cada processo.
model ProcessoAndamento {
  id         String   @id @default(cuid())
  processoId String
  processo   Processo @relation(fields: [processoId], references: [id])
  texto      String
  autor      String // iniciais de quem registrou
  tarefaId   String   @default("") // tarefa que originou o resumo (se houver)
  criadoEm   DateTime @default(now())

  @@index([processoId])
}

model Tarefa {
  id           String    @id @default(cuid())
  titulo       String
  descricao    String?
  processoId   String?
  processo     Processo? @relation(fields: [processoId], references: [id])
  area         String // trabalhista | civel
  prazo        String
  data         String // ISO yyyy-mm-dd (posição no calendário = prazo final/data fatal)
  dataDisponibilizacao String @default("") // yyyy-mm-dd (saída no DJe)
  dataPublicacao       String @default("") // yyyy-mm-dd (1º dia útil após a disponibilização; base da contagem)
  prazoDias            Int    @default(5) // quantidade de dias do prazo
  prazoTipo            String @default("uteis") // uteis | corridos
  prazoUrgente Boolean   @default(false)
  status       String    @default("a_fazer") // a_fazer | em_curso | concluida
  responsaveis String[] // iniciais (pode ter mais de um)
  solicitante  String   @default("") // iniciais — cível: Débora · trabalhista: Karen
  revisor      String   @default("") // iniciais — cível: Mauro · trabalhista: Karen
  origem       String    @default("manual") // manual | aasp
  concluidaEm  DateTime? // carimbo de quando passou para "concluida" (nulo se ainda não)
  criadoEm     DateTime  @default(now())
}

// Linha do tempo da tarefa: comentários livres + registro automático de
// mudanças (status, responsáveis, prazo). "autor" guarda as iniciais (ou
// "sistema"); "tipo" distingue comentário de mudança para o ícone/estilo.
model TarefaHistorico {
  id       String   @id @default(cuid())
  tarefaId String
  autor    String // iniciais do usuário (ou "sistema")
  tipo     String // comentario | criacao | status | responsaveis | prazo
  texto    String   @default("") // comentário livre OU descrição da mudança
  criadoEm DateTime @default(now())

  @@index([tarefaId])
}

model Documento {
  id              String   @id @default(cuid())
  processoId      String
  processo        Processo @relation(fields: [processoId], references: [id])
  ordem           Int
  nome            String // limite de 255 garantido na aplicação (criarDocumento)
  data            String
  driveFileId     String?
  caminhoServidor String?
  // Upload real via Vercel Blob. blobUrl fica só no servidor; o download é
  // servido por rota autenticada (/api/documentos/[id]).
  blobUrl         String?
  tamanho         Int      @default(0) // bytes
  mime            String   @default("")
  criadoEm        DateTime @default(now())

  @@unique([processoId, ordem])
}

model Publicacao {
  id                 String    @id @default(cuid())
  processoId         String?
  processo           Processo? @relation(fields: [processoId], references: [id])
  numero             String // CNJ do processo
  area               String
  tribunal           String
  tipo               String // tipo de ato: sentenca | despacho | decisao | acordao | pauta | ...
  partes             String
  despacho           String // teor/dispositivo extraído
  prazo              String
  data               String    @default("") // = disponibilização (posição no calendário)
  processoCadastrado Boolean   @default(false)
  statusTriagem      String    @default("pendente") // pendente | processada | ignorada
  // Campos da importação AASP/DJEN
  orgao                 String   @default("")
  poloAtivo             String   @default("")
  poloPassivo           String   @default("")
  resultado             String   @default("") // procedente | improcedente | parcial | ""
  dataPublicacao        String   @default("") // 1º dia útil após a disponibilização
  vencimentoLegal       String   @default("")
  dataFatal             String   @default("") // vencimento − 1 dia (margem)
  prazoDias             Int      @default(0)
  prazoTipo             String   @default("uteis")
  intimado              String   @default("")
  cliente               String   @default("") // cliente casado na base
  acaoSugerida          String   @default("")
  responsaveisSugeridos String[] @default([])
  atoId                 String   @default("")
  publicacaoNum         String   @default("")
  chave                 String   @default("") // dedup de reimportação
  tarefaId              String   @default("") // tarefa criada a partir desta publicação
  criadoEm           DateTime  @default(now())

  @@index([statusTriagem])
  @@index([chave])
}

// PDF original da AASP guardado no import da triagem, para gerar o grifado
// depois sem precisar subir o arquivo de novo. Mantemos só os mais recentes.
model ArquivoAASP {
  id       String   @id @default(cuid())
  nome     String   @default("")
  data     String   @default("") // disponibilização (ISO) — para o nome do grifado
  bytes    Bytes
  criadoEm DateTime @default(now())

  @@index([criadoEm])
}

model EventoAgenda {
  id       String   @id @default(cuid())
  data     String   @default("") // yyyy-mm-dd
  hora     String
  tipo     String // reuniao | audiencia | prazo | atendimento
  titulo        String
  detalhe       String
  participantes String[]
  criadoEm      DateTime @default(now())
}

model Audiencia {
  id            String     @id @default(cuid())
  processoId    String?
  processo      Processo?  @relation(fields: [processoId], references: [id])
  titulo        String
  data          String // yyyy-mm-dd (horário de Brasília)
  hora          String // HH:MM (horário de Brasília)
  inicioUtc     DateTime // instante absoluto (data+hora BRT convertidos p/ UTC)
  tipo          String     @default("instrucao") // instrucao | conciliacao | inicial | una | outra
  modalidade    String     @default("presencial") // presencial | virtual
  link          String     @default("") // link da sala (quando virtual)
  local         String     @default("")
  partes        String     @default("")
  participantes String[]
  observacoes   String     @default("")
  status        String     @default("agendada") // agendada | realizada | cancelada
  criadoEm      DateTime   @default(now())
  lembretes     Lembrete[]
}

model Lembrete {
  id          String    @id @default(cuid())
  audienciaId String
  audiencia   Audiencia @relation(fields: [audienciaId], references: [id], onDelete: Cascade)
  offsetMin   Int // minutos antes do início
  enviadoEm   DateTime? // nulo até ser enviado (evita reenvio)
  criadoEm    DateTime  @default(now())
}
